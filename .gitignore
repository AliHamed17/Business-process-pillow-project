# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Data files (ignored since they are large and shouldn't be in Git)
data/
*.csv
*.xlsx
*.zip
*.xes

# Virtual Environments
venv/
.venv/
env/
.env/

# Outputs (graphs, generated plots and results)
# You might want to track some analysis outputs, but typically they are generated by code
# outputs/
outputs/*.csv
outputs/*.xes
outputs/models/
outputs/plots/

# IDE files
.vscode/
.idea/
.ipynb_checkpoints/
