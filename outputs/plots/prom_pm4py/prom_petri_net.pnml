      </transition>
      <transition id="fad52ebf-04b9-4188-a4f2-2ddd20bd0c33">
        <name>
          <text>אישור ראש מינהל</text>
        </name>
      </transition>
      <transition id="42c5ec98-c158-41c7-8b19-ed740b4e4e0b">
        <name>
          <text>החלטת הועדה - התאמת מועמדים - ללא מכרז</text>
        </name>
      </transition>
      <transition id="b69e5a64-049e-4ba5-8b1e-7c30122a8902">
