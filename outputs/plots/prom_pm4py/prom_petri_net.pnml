      </transition>
      <transition id="04a7d4ce-17c2-4e8a-999f-f44921c4e928">
        <name>
          <text>חוזה נחתם ע"י כל הגורמים</text>
        </name>
      </transition>
      <transition id="3c27e5cd-c4e3-414d-a675-5e9e75fb3ae9">
        <name>
          <text>אישור יידוע נוסח המכרז נציג ועד העובדים</text>
