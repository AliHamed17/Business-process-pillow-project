      <transition id="ba1d6950-f38e-4f5a-ba1f-dd50bf91b2cc">
        <name>
          <text>מכרז פנימי לפרסום</text>
        </name>
      </transition>
      <transition id="05ac80c4-cbfb-4d05-9967-a671beb5277b">
